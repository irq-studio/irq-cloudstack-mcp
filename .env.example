# CloudStack MCP Server Environment Configuration Example
# Copy this file to .env and fill in your CloudStack credentials

# CloudStack API Configuration
CLOUDSTACK_API_URL=https://your-cloudstack-server/client/api
CLOUDSTACK_API_KEY=your-api-key-here
CLOUDSTACK_SECRET_KEY=your-secret-key-here
CLOUDSTACK_TIMEOUT=30000

# Rate Limiting Configuration (optional)
# CLOUDSTACK_RATE_LIMIT_MAX_REQUESTS=100
# CLOUDSTACK_RATE_LIMIT_WINDOW_MS=60000
# CLOUDSTACK_RATE_LIMIT_BURST_SIZE=120

# Retry Configuration (optional)
# CLOUDSTACK_MAX_RETRIES=3
# CLOUDSTACK_RETRY_INITIAL_DELAY_MS=1000
# CLOUDSTACK_RETRY_MAX_DELAY_MS=10000
# CLOUDSTACK_RETRY_BACKOFF_MULTIPLIER=2

# Batch Operations Configuration (optional)
# CLOUDSTACK_BATCH_CONCURRENCY=10

# Validation Configuration (optional)
# CLOUDSTACK_MAX_ARRAY_SIZE=100

# Metrics Configuration (optional)
# CLOUDSTACK_MAX_STORED_METRICS=1000

# VM Operations Configuration (optional)
# CLOUDSTACK_STOP_VM_WAIT_MS=2000

# Connection Pool Configuration (optional)
# CLOUDSTACK_POOL_KEEP_ALIVE=true
# CLOUDSTACK_POOL_KEEP_ALIVE_MS=30000
# CLOUDSTACK_POOL_MAX_SOCKETS=50
# CLOUDSTACK_POOL_MAX_FREE_SOCKETS=10
# CLOUDSTACK_POOL_SOCKET_TIMEOUT=60000

# Server Configuration (optional)
PORT=8080

# Environment (optional)
NODE_ENV=development