{
    "name": "irq-cloudstack-mcp",
    "version": "0.5.0",
    "description": "MCP server for Apache CloudStack API",
    "type": "module",
    "main": "build/index.js",
    "bin": {
        "irq-cloudstack-mcp": "build/index.js",
        "cloudstack-cli": "build/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "dev:cli": "tsx src/cli.ts",
        "dev:bun": "bun run src/index.ts",
        "dev:bun:cli": "bun run src/cli.ts",
        "start": "node build/index.js",
        "cli": "node build/cli.js",
        "compile": "bun build --compile --minify src/index.ts --outfile dist/irq-cloudstack-mcp",
        "compile:cli": "bun build --compile --minify src/cli.ts --outfile dist/cloudstack-cli",
        "compile:linux": "bun build --compile --target=bun-linux-x64 --minify src/index.ts --outfile dist/cloudstack-mcp-linux-x64",
        "compile:linux:cli": "bun build --compile --target=bun-linux-x64 --minify src/cli.ts --outfile dist/cloudstack-cli-linux-x64",
        "compile:all": "npm run compile && npm run compile:cli && npm run compile:linux && npm run compile:linux:cli",
        "lint": "eslint src/ tests/",
        "lint:fix": "eslint src/ tests/ --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "validate": "npm run build && node scripts/validate-functions.js",
        "prepare": "npm run build"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.26.0",
        "axios": "^1.13.5",
        "cli-table3": "^0.6.3",
        "commander": "^11.1.0",
        "dotenv": "^16.3.1",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/eslint__js": "^8.42.3",
        "@types/jest": "^29.5.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.0.0",
        "@types/supertest": "^2.0.16",
        "eslint": "^9.39.1",
        "jest": "^29.5.0",
        "supertest": "^6.3.4",
        "ts-jest": "^29.4.5",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.0"
    },
    "keywords": [
        "mcp",
        "cloudstack",
        "api",
        "server"
    ],
    "license": "MIT",
    "overrides": {
        "hono": ">=4.11.7"
    }
}
